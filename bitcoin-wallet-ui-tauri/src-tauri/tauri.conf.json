{
  "$schema": "https://raw.githubusercontent.com/nicuveo/tauri-v2-schema/refs/heads/main/tauri.schema.json",
  "productName": "Bitcoin Wallet",
  "version": "0.1.0",
  "identifier": "com.bitcoin.wallet-ui",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Bitcoin Wallet",
        "width": 1024,
        "height": 768,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self'; img-src 'self' data:"
    }
  },
  "plugins": {
    "clipboard-manager": {
      "all": true
    },
    "shell": {
      "open": true
    }
  }
}
